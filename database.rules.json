{
  "rules": {
    "games": {
      ".read": true,
      "$code": {
        ".write": "$code.matches(/^[A-HJ-NP-Z2-9]{6}$/)",
        ".validate": "newData.exists() && newData.child('code').isString() && newData.child('code').val() === $code",
        "$other": {
          ".validate": true
        }
      }
    }
  }
}
